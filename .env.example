APP_ENV=development
DEV_PAYMENT_BYPASS=true
APP_BASE_URL=http://localhost:8000

# Stripe MVP payments. Amounts are integer cents.
STRIPE_SECRET_KEY=
STRIPE_CURRENCY=usd
STRIPE_LOW_SEVERITY_CENTS=50
STRIPE_MEDIUM_SEVERITY_CENTS=50
STRIPE_HIGH_SEVERITY_CENTS=50

# Required for higher GitHub rate limits. Public unauthenticated requests work for small demos.
GITHUB_TOKEN=

# Optional. Enables LLM clustering instead of heuristic clustering.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional. Enables ClickHouse persistence.
CLICKHOUSE_HOST=
CLICKHOUSE_PORT=8443
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=default
CLICKHOUSE_SECURE=true

# Datadog APM + LLM Observability (use with: ./run.sh or ddtrace-run uvicorn ...)
DD_API_KEY=
DD_SITE=us5.datadoghq.com
DD_SERVICE=docs-gap-agent
DD_ENV=development
DD_LLMOBS_ENABLED=1
DD_LLMOBS_ML_APP=gitshell

# Optional. Enables LangSmith traces and LangGraph Studio debugging.
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=docs-gap-agent
LANGSMITH_ENDPOINT=

# Placeholder for the next phase.
SENSO_API_KEY=
NIMBLE_API_KEY=
GITHUB_NOTIFY_TOKEN=
